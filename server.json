{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.sharedmemoryai/memory",
  "description": "Persistent memory for AI agents. Remember, recall, and explore a shared knowledge graph.",
  "repository": {
    "url": "https://github.com/sharedmemoryai/mcp-server",
    "source": "github"
  },
  "version": "2.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@sharedmemory/mcp-server",
      "version": "2.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your SharedMemory API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "SHAREDMEMORY_API_KEY"
        },
        {
          "description": "API endpoint URL",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "SHAREDMEMORY_API_URL"
        },
        {
          "description": "Default volume/project ID",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "SHAREDMEMORY_VOLUME_ID"
        }
      ]
    }
  ]
}
